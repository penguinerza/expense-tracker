# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://yourdomain.com/api/auth/callback

# Single authorized user (Google user ID from OAuth)
AUTHORIZED_GOOGLE_USER_ID=

# Session — signs the session cookie. Generate your own random value (>=32 chars):
#   openssl rand -base64 48
JWT_SECRET=change-this-to-a-random-secret-at-least-32-chars

# Cloudflare R2 — daily snapshot backups (optional; enabled by default)
# Set to false to disable backups entirely; the R2_* vars below are then unused.
R2_BACKUP_ENABLED=true
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=expense-tracker-snapshots
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# App
PORT=3001
NODE_ENV=production
FRONTEND_URL=https://yourdomain.com

# Dev only — set to true to skip Google login (never set in production)
# DEV_BYPASS_AUTH=true
